# Supply-chain hardening: pin exact versions and always maintain the lockfile.
# New `npm install <pkg>` records an exact version (no ^ range), and the
# committed package-lock.json (with integrity hashes) is the source of truth —
# CI installs with `npm ci`, so the full transitive tree is reproducible.
# NOTE: keep this file free of any tokens/secrets — it is committed.
save-exact=true
package-lock=true
