{
  "name": "very-nice-mermaid",
  "version": "0.6.3",
  "description": "A framework-agnostic Mermaid flowchart renderer: parse the DSL, auto-layout with dagre, and render beautiful interactive HTML, static SVG, PNG, or ASCII — no mermaid.js runtime, no headless browser.",
  "type": "module",
  "license": "MIT",
  "author": "Bartlomiej Zawadzki",
  "homepage": "https://github.com/ZawadzkiB/very-nice-mermaid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZawadzkiB/very-nice-mermaid.git"
  },
  "bugs": {
    "url": "https://github.com/ZawadzkiB/very-nice-mermaid/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mermaid",
    "flowchart",
    "diagram",
    "svg",
    "renderer",
    "dagre",
    "interactive",
    "web-component"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "vnm": "dist/cli/index.js",
    "very-nice-mermaid": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude test/cli.test.ts",
    "test:cli": "vitest run test/cli.test.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run build && npm run typecheck && npm run test && npm run test:e2e",
    "prepublishOnly": "npm run build",
    "examples": "node scripts/generate-examples.mjs",
    "docs": "node scripts/generate-docs.mjs",
    "heroes": "node scripts/generate-heroes.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "1.1.8",
    "commander": "12.1.0",
    "jsdom": "25.0.1",
    "mermaid": "11.16.0"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "2.6.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.0",
    "fast-xml-parser": "4.5.7",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
