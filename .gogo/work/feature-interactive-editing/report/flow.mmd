flowchart LR
  drag["drag node"]:::io
  sel["select node"]:::io
  resize["drag corner handle<br/>(min-size clamp)"]:::proc
  grpgrab["grab subgraph<br/>border / title band"]:::io
  grpmove["move all members<br/>(group drag)"]:::proc
  contain["auto-contain box<br/>computeSubgraphBoxes (shared)"]:::proc
  epdrag["drag edge endpoint<br/>handle (.vnm-edge-handle)"]:::io
  pin["pin {side,offset}<br/>anchorsOv (override)"]:::proc
  ports["computePerimeterPorts<br/>raySide + spread + overrides"]:::proc
  reroute["live re-route edges<br/>(routeEdge, offset-removed coords)"]:::proc
  persist["exportLayout + localStorage<br/>(positions + sizes + anchors)"]:::art
  svgstr["toSvgString() inlined<br/>(byte-parity with render/svg)"]:::proc
  savesvg["Save SVG<br/>(data-URI download)"]:::out
  savepng["Save PNG<br/>(canvas → toDataURL)"]:::out
  reset["Reset layout (⟲)<br/>discard moves + resizes + pins"]:::io
  restore["restore computed<br/>positions + sizes; clear pins"]:::proc
